@startuml
title Simplified System and Code Structure of the Implemented Pipeline
left to right direction
skinparam componentStyle rectangle

rectangle "Input Data\n(dataset/images + labels.csv)" as InputData
rectangle "Runtime Inputs\n(webcam / single image)" as RuntimeInputs

package "Core Pipeline" {
  rectangle "Detection + Preprocessing\n(utils/face_detect.py, preprocessing)" as Detect
  rectangle "Attribute Inference\n(utils/deepface_predict.py)" as Infer
}

package "Execution Paths" {
  rectangle "main.py\n(interactive app)" as Main
  rectangle "evaluate.py\n(quality metrics)" as Evaluate
  rectangle "performance.py\n(CPU/GPU benchmark)" as Benchmark
  rectangle "tflite_inference.py\n(TFLite timing)" as TFLite
  rectangle "mobile_eval_server.py\n(iPhone browser timing)" as Mobile
}

package "Outputs" {
  file "results/*.csv\nmetrics, predictions" as CsvOut
  file "results/*.png\ncomparison charts" as PlotOut
}

InputData --> Detect
RuntimeInputs --> Infer
Detect --> Infer

Detect --> Main
Detect --> Evaluate
Infer --> Benchmark
Infer --> TFLite
Infer --> Mobile

Evaluate --> CsvOut
Benchmark --> PlotOut

@enduml
