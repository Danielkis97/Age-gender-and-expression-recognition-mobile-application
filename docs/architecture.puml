@startuml
title Age, Gender, and Emotion Recognition - High-Level Architecture
left to right direction
skinparam componentStyle rectangle

actor User

package "Application Layer" {
  [main.py] as Main
  [evaluate.py] as Evaluate
  [performance.py] as Benchmark
  [tflite_export.py] as Export
  [tflite_inference.py] as TFLite
}

package "Project Assets" {
  folder "dataset/" as Dataset
  folder "utils/" as Utils
  folder "results/" as Results
  file "models/model.tflite" as Model
}

User --> Main : webcam / image mode
User --> Evaluate : evaluation run
User --> Benchmark : performance run
User --> Export : export demo model
User --> TFLite : timing run

Main --> Utils : face detection / prediction helpers
Main --> Dataset : read images
Main --> Results : write outputs

Evaluate --> Utils : label mapping / prediction helpers
Evaluate --> Dataset : read images + labels
Evaluate --> Results : write metrics

Benchmark --> Dataset : read images
Benchmark --> Results : write benchmark files
Benchmark --> TFLite : include TFLite timings

Export --> Model : create .tflite file
TFLite --> Model : load model
TFLite --> Dataset : read face crops
TFLite --> Results : write timing csv

@enduml
